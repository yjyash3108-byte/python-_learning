# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/scholarnet

# JWT — generate a long random string for production
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256

# CORS / reset links (use https:// in production)
FRONTEND_URL=http://localhost:3000
PASSWORD_RESET_EXPIRE_MINUTES=15

# Cloudinary (production image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (password reset + Pro confirmation)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=noreply@scholarnet.app

# Razorpay — ScholarNet Pro (₹299/month)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
PRO_PLAN_NAME=ScholarNet Pro
PRO_PLAN_AMOUNT_INR=299
PRO_PLAN_DURATION_DAYS=30

# Free tier club limits
FREE_MAX_CLUBS_CREATED=1
FREE_MAX_CLUB_MEMBERS=50
FREE_MAX_CLUB_ADMINS=1
FREE_MAX_CLUB_EVENTS=3
FREE_MAX_CLUB_ANNOUNCEMENTS=5

# Parent weekly digest — run via cron (see README):
# python scripts/parent_digest.py

# AI Club Assistant (optional — smart fallback if unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
